# Minion gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into minion's ~/.config/containers/systemd/
# {{MINION_HOME}} is replaced at install time.

[Unit]
Description=Minion gateway (rootless Podman)

[Container]
Image=minion:local
ContainerName=minion
UserNS=keep-id
Volume={{MINION_HOME}}/.minion:/home/node/.minion
EnvironmentFile={{MINION_HOME}}/.minion/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
